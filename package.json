{
    "name": "@loyslow/opencode-voice-groq",
    "version": "0.1.1",
    "bin": {
        "opencode-voice-groq": "bin/cli.js"
    },
    "description": "Groq voice input plugin for OpenCode",
    "type": "module",
    "license": "MIT",
    "readmeFilename": "README.md",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ihxnnxs/opencode-voice.git"
    },
    "bugs": {
        "url": "https://github.com/ihxnnxs/opencode-voice/issues"
    },
    "homepage": "https://github.com/ihxnnxs/opencode-voice#readme",
    "main": "./index.js",
    "exports": {
        ".": {
            "import": "./index.js"
        },
        "./tui": {
            "import": "./index.js"
        },
        "./runtime": {
            "import": "./lib/engine.js"
        }
    },
    "files": [
        "assets/",
        "bin/",
        "lib/",
        "index.js",
        "CHANGELOG.md",
        "CONTRIBUTING.md",
        "PUBLISHING.md",
        "README.md",
        "docs/README*.md",
        "SECURITY.md",
        "LICENSE"
    ],
    "scripts": {
        "prepack": "node -c index.js && node -c lib/engine.js"
    },
    "dependencies": {
        "ffmpeg-static": "^5.2.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "peerDependencies": {
        "@opencode-ai/plugin": ">=1.17.4 <2"
    },
    "peerDependenciesMeta": {
        "@opencode-ai/plugin": {
            "optional": true
        }
    },
    "keywords": [
        "opencode",
        "opencode-plugin",
        "voice",
        "speech-to-text",
        "whisper",
        "whisper.cpp"
    ],
    "engines": {
        "node": ">=20",
        "opencode": ">=1.17.4"
    }
}
